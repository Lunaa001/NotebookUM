# Aplicación
APP_NAME=NotebookUM
VERSION=0.1.0
DEBUG=True

# Servidor
HOST=0.0.0.0
PORT=8000

# CORS - Orígenes permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Base de datos
DATABASE_URL=sqlite:///./notebookum.db

FLASK_APP = run.py

FLASK_ENV = development

SECRET_KEY = 

URL_API = https://ai.cloud.edu.um.ar/api/v1
